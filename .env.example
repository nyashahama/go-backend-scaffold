# Server
PORT=8080
ENV=development

# Local development only. Do not reuse these transport settings in production.
# Database (postgres)
DATABASE_URL=postgres://user:change-me-local-dev@localhost:5432/scaffold?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Auth
# Replace before running; config validation rejects the example placeholder.
JWT_SECRET=changeme-use-openssl-rand-base64-32
JWT_EXPIRY=15m
REFRESH_EXPIRY=168h

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Example App

# Optional: protect /metrics in production when enabled.
METRICS_BEARER_TOKEN=

# App
APP_BASE_URL=http://localhost:3000

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
